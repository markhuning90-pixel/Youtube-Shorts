Dialogue: 0,0:00:00.00,0:00:01.58,Shorts,,0,0,0,,Wusstest du,
Dialogue: 0,0:00:01.58,0:00:03.17,Shorts,,0,0,0,,dass Katzen bis zu 16
Dialogue: 0,0:00:03.17,0:00:04.75,Shorts,,0,0,0,,Stunden am Tag schlafen?
Dialogue: 0,0:00:04.75,0:00:06.34,Shorts,,0,0,0,,Sie sparen Energie für die
Dialogue: 0,0:00:06.34,0:00:07.92,Shorts,,0,0,0,,Jagd. Das ist ein Urinstinkt.
Dialogue: 0,0:00:07.92,0:00:09.50,Shorts,,0,0,0,,Junge und alte Katzen brauchen
Dialogue: 0,0:00:09.50,0:00:11.09,Shorts,,0,0,0,,mehr Ruhe.
Dialogue: 0,0:00:11.09,0:00:12.67,Shorts,,0,0,0,,Katzen sind dämmerungsaktiv.
Dialogue: 0,0:00:12.67,0:00:14.26,Shorts,,0,0,0,,Sie jagen vor allem morgens
Dialogue: 0,0:00:14.26,0:00:15.84,Shorts,,0,0,0,,und abends.
Dialogue: 0,0:00:15.84,0:00:17.42,Shorts,,0,0,0,,Tagsüber ruhen sie viel.
Dialogue: 0,0:00:17.42,0:00:19.01,Shorts,,0,0,0,,Viele kurze Nickerchen statt eines
Dialogue: 0,0:00:19.01,0:00:20.59,Shorts,,0,0,0,,langen Schlafs.
Dialogue: 0,0:00:20.59,0:00:22.18,Shorts,,0,0,0,,Ihr Schlaf hat zwei Phasen:
Dialogue: 0,0:00:22.18,0:00:23.76,Shorts,,0,0,0,,leichter Schlaf und REM.
Dialogue: 0,0:00:23.76,0:00:25.34,Shorts,,0,0,0,,Im leichten Schlaf bleiben sie
Dialogue: 0,0:00:25.34,0:00:26.93,Shorts,,0,0,0,,wachsam. Im REM träumen sie
Dialogue: 0,0:00:26.93,0:00:28.51,Shorts,,0,0,0,,und erholen sich tief.
Dialogue: 0,0:00:28.51,0:00:30.10,Shorts,,0,0,0,,Schlaf hilft auch beim Wachstum
Dialogue: 0,0:00:30.10,0:00:31.68,Shorts,,0,0,0,,und der Immunabwehr.
Dialogue: 0,0:00:31.68,0:00:33.26,Shorts,,0,0,0,,Gib deiner Katze ruhige Plätze
Dialogue: 0,0:00:33.26,0:00:34.85,Shorts,,0,0,0,,und regelmäßiges Spiel.
Dialogue: 0,0:00:34.85,0:00:36.43,Shorts,,0,0,0,,So bleibt sie tagsüber aktiver.
